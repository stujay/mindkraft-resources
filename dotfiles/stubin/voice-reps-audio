#!/bin/bash

# STUJAYs-Voice-Reps: Copyright Stuart Jay Raj
# This software is licensed under a non-commercial use license.
# Please contact the author for any commercial usage.
# This script is used to generate audio files with repetitions
# and pauses between sentences and languages.

# Color definitions
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
ORANGE='\033[0;33m'
NC='\033[0m' # No Color

# Function to check if the script is running on a Mac
check_mac() {
  if [[ "$OSTYPE" != "darwin"* ]]; then
    echo -e "${ORANGE}Sorry, this script can only run on a Mac.${NC}"
    exit 1
  fi
}

# Function to check if fzf is installed
check_fzf() {
  if ! command -v fzf &> /dev/null; then
    echo -e "${YELLOW}fzf is not installed. Would you like to install it? (y/n)${NC}"
    read -r response
    response=$(echo "$response" | tr '[:upper:]' '[:lower:]')
    if [[ "$response" == "y" || "$response" == "yes" ]]; then
      if ! command -v brew &> /dev/null; then
        echo -e "${ORANGE}Homebrew is not installed. Please install Homebrew first from https://brew.sh/${NC}"
        exit 1
      fi
      echo -e "${YELLOW}Installing fzf...${NC}"
      brew install fzf
    else
      echo -e "${ORANGE}fzf is required for custom sentence selection. Exiting.${NC}"
      exit 1
    fi
  fi
}

# Function to check if jq is installed
check_jq() {
  if ! command -v jq &> /dev/null; then
    echo -e "${YELLOW}jq is not installed. Would you like to install it? (y/n)${NC}"
    read -r response
    response=$(echo "$response" | tr '[:upper:]' '[:lower:]')
    if [[ "$response" == "y" || "$response" == "yes" ]]; then
      if ! command -v brew &> /dev/null; then
        echo -e "${ORANGE}Homebrew is not installed. Please install Homebrew first from https://brew.sh/${NC}"
        exit 1
      fi
      echo -e "${YELLOW}Installing jq...${NC}"
      brew install jq
    else
      echo -e "${ORANGE}jq is required to run this script. Exiting.${NC}"
      exit 1
    fi
  fi
}

# Function to check if gawk is installed
check_gawk() {
  if ! command -v gawk &> /dev/null; then
    echo -e "${YELLOW}gawk is not installed. Would you like to install it? (y/n)${NC}"
    read -r response
    response=$(echo "$response" | tr '[:upper:]' '[:lower:]')
    if [[ "$response" == "y" || "$response" == "yes" ]]; then
      if ! command -v brew &> /dev/null; then
        echo -e "${ORANGE}Homebrew is not installed. Please install Homebrew first from https://brew.sh/${NC}"
        exit 1
      fi
      echo -e "${YELLOW}Installing gawk...${NC}"
      brew install gawk
    else
      echo -e "${ORANGE}gawk is required to run this script. Exiting.${NC}"
      exit 1
    fi
  fi
}

# Check if running on a Mac and if required tools are installed
check_mac
check_fzf
check_jq
check_gawk

# Input Parameters
INPUTFILE=$1

# Determine the default field separator based on file extension
EXTENSION="${INPUTFILE##*.}"
if [[ "$EXTENSION" == "tsv" ]]; then
    FIELD_SEPARATOR=$'\t'
else
    FIELD_SEPARATOR=','
fi

# Override field separator if provided as a second argument
if [[ "$2" == "-F"* ]]; then
    FIELD_SEPARATOR=${2:2}
fi

echo -e "${BLUE}voice-reps first-words.tsv${NC}"
echo -e "${ORANGE}Column headers:${NC}"
head -n 1 "$INPUTFILE" | gawk -F"$FIELD_SEPARATOR" '{for(i=1; i<=NF; i++) print i, $i}'

LANGUAGE_SELECTIONS=()
VOICE_SELECTIONS=()
REPETITIONS=()
COLUMN_SELECTIONS=()

# Store the output of say -v \? into an array
IFS=$'\n' read -r -d '' -a VOICES_ARRAY < <(say -v \? && printf '\0')

# Function to display available languages and get user input
function select_language() {
  echo -e "${YELLOW}Available languages: ar (Arabic), bg (Bulgarian), ca (Catalan), cs (Czech), da (Danish), de (German), el (Greek), en (English), es (Spanish), fi (Finnish), fr (French), he (Hebrew), hi (Hindi), hr (Croatian), hu (Hungarian), id (Indonesian), it (Italian), ja (Japanese), ko (Korean), ms (Malay), nb (Norwegian), nl (Dutch), pl (Polish), pt (Portuguese), ro (Romanian), ru (Russian), sk (Slovak), sv (Swedish), th (Thai), tr (Turkish), uk (Ukrainian), vi (Vietnamese), zh (Chinese)${NC}"
  read -p "Enter a two-letter language code: " lang_code
}

# Function to get the list of available voices and filter by language code
function filter_voices() {
  lang_code_lower=$(echo "$lang_code" | tr '[:upper:]' '[:lower:]')
  filtered_voices=$(printf "%s\n" "${VOICES_ARRAY[@]}" | awk -v lang="$lang_code_lower" '
  {
    if (tolower(substr($2, 1, 2)) == lang || tolower($3) ~ tolower(lang)) {
      print NR ") " $1 " (" $2 ")"
    }
  }')
  echo "$filtered_voices"
}

while true; do
  echo -e "${BLUE}STUJAYs-Voice-Reps: Adding Language $((${#LANGUAGE_SELECTIONS[@]} + 1)) (up to 5 languages)${NC}"
  echo -e "${ORANGE}STUJAYs-Voice-Reps: Select the column number for Language $((${#LANGUAGE_SELECTIONS[@]} + 1)):${NC}"
  read -r column_number

  select_language

  available_voices=$(filter_voices)
  if [[ -z "$available_voices" ]]; then
    echo -e "${ORANGE}No voices available for the selected language.${NC}"
    exit 1
  fi

  echo "$available_voices"
  echo -e "${YELLOW}Pick a speaker by their adjacent number:${NC}"
  read -r speaker_number

  chosen_voice=$(printf "%s\n" "${VOICES_ARRAY[@]}" | awk 'NR=='"$speaker_number"' {print $1 " " $2}')
  voice_name=$(echo "$chosen_voice" | awk '{print $1}')
  voice_iso=$(echo "$chosen_voice" | awk '{print $2}')
  echo -e "${BLUE}You chose $voice_name ($voice_iso)${NC}"
  echo -e "${YELLOW}How many repetitions? (1-3, default 1):${NC}"
  read -r repetitions
  repetitions=${repetitions:-1}

  LANGUAGE_SELECTIONS+=("$lang_code")
  VOICE_SELECTIONS+=("$voice_name ($voice_iso)")
  REPETITIONS+=("$repetitions")
  COLUMN_SELECTIONS+=("$column_number")

  if [[ ${#LANGUAGE_SELECTIONS[@]} -ge 5 ]]; then
    break
  fi

  echo -e "${YELLOW}Would you like to add another Language? (y/n):${NC}"
  read -r add_language
  if [[ "$add_language" != "y" && "$add_language" != "yes" ]]; then
    break
  fi
done

echo -e "${YELLOW}Would you like to select a range, or use fuzzy finder (fzf) to customize selected sentences?${NC}"
echo -e "${ORANGE}1) Range${NC}"
echo -e "${ORANGE}2) Fuzzy Finder${NC}"
read -r selection_method

if [[ "$selection_method" == "1" ]]; then
  echo -e "${YELLOW}Enter the range of sentence numbers (e.g., 1-10):${NC}"
  read -r range
  sentences=$(awk -F"$FIELD_SEPARATOR" -v range="$range" 'NR==1 || NR>=range && NR<=range {print}' "$INPUTFILE")
elif [[ "$selection_method" == "2" ]]; then
  sentences=$(cat "$INPUTFILE" | fzf --multi)
else
  echo -e "${ORANGE}Invalid selection method. Exiting.${NC}"
  exit 1
fi

# Display a summary of the selected options and sentences
echo -e "${BLUE}Summary of selections:${NC}"
echo -e "${YELLOW}Languages and voices:${NC}"
for i in "${!LANGUAGE_SELECTIONS[@]}"; do
  lang_code=${LANGUAGE_SELECTIONS[$i]}
  case "$lang_code" in
    ar) lang_name="Arabic" ;;
    bg) lang_name="Bulgarian" ;;
    ca) lang_name="Catalan" ;;
    cs) lang_name="Czech" ;;
    da) lang_name="Danish" ;;
    de) lang_name="German" ;;
    el) lang_name="Greek" ;;
    en) lang_name="English" ;;
    es) lang_name="Spanish" ;;
    fi) lang_name="Finnish" ;;
    fr) lang_name="French" ;;
    he) lang_name="Hebrew" ;;
    hi) lang_name="Hindi" ;;
    hr) lang_name="Croatian" ;;
    hu) lang_name="Hungarian" ;;
    id) lang_name="Indonesian" ;;
    it) lang_name="Italian" ;;
    ja) lang_name="Japanese" ;;
    ko) lang_name="Korean" ;;
    ms) lang_name="Malay" ;;
    nb) lang_name="Norwegian" ;;
    nl) lang_name="Dutch" ;;
    pl) lang_name="Polish" ;;
    pt) lang_name="Portuguese" ;;
    ro) lang_name="Romanian" ;;
    ru) lang_name="Russian" ;;
    sk) lang_name="Slovak" ;;
    sv) lang_name="Swedish" ;;
    th) lang_name="Thai" ;;
    tr) lang_name="Turkish" ;;
    uk) lang_name="Ukrainian" ;;
    vi) lang_name="Vietnamese" ;;
    zh) lang_name="Chinese" ;;
    *) lang_name="Unknown" ;;
  esac
  echo -e "${ORANGE}Language $((i+1)):${NC}"
  echo -e "${YELLOW}Language Name: ${NC}${lang_name}"
  echo -e "${YELLOW}Language Code: ${NC}${LANGUAGE_SELECTIONS[$i]}"
  echo -e "${YELLOW}Voice: ${NC}${VOICE_SELECTIONS[$i]}"
  echo -e "${YELLOW}Repetitions: ${NC}${REPETITIONS[$i]}"
  echo -e "${YELLOW}Column: ${NC}${COLUMN_SELECTIONS[$i]}"
  echo -e "${BLUE}------------------------${NC}"
done

echo -e "${YELLOW}Selected sentences:${NC}"
IFS=$'\n'
for sentence in $sentences; do
  echo -e "${ORANGE}Sentence $(echo "$sentence" | awk -F"$FIELD_SEPARATOR" '{print $1}')${NC}"
  for i in "${!COLUMN_SELECTIONS[@]}"; do
    column_index=${COLUMN_SELECTIONS[$i]}
    column_value=$(echo "$sentence" | awk -F"$FIELD_SEPARATOR" -v col="$column_index" '{print $col}')
    echo -e "${YELLOW}Language $((i+1)) (${LANGUAGE_SELECTIONS[$i]}): ${NC}$column_value"
  done
  echo -e "${BLUE}------------------------${NC}"
done

# Process lines and generate audio
process_lines() {
  local tempfolder="tmp-voice-reps"
  rm -rf "$tempfolder"
  mkdir -p "$tempfolder"

  local sentence_count=0
  for sentence in $sentences; do
    sentence_number=$(echo "$sentence" | awk -F"$FIELD_SEPARATOR" '{print $1}')
    for i in "${!COLUMN_SELECTIONS[@]}"; do
      column_index=${COLUMN_SELECTIONS[$i]}
      column_value=$(echo "$sentence" | awk -F"$FIELD_SEPARATOR" -v col="$column_index" '{print $col}')
      voice_name=$(echo "${VOICE_SELECTIONS[$i]}" | awk '{print $1}')
      for ((r=1; r<=${REPETITIONS[$i]}; r++)); do
        echo -e "${ORANGE}Processing sentence $sentence_number, Language $((i+1)): $column_value, Repetition $r${NC}"
        say -v "$voice_name" "[[slnc 1000]] $column_value [[slnc 1000]]" -o "${tempfolder}/${sentence_number}_lang${i}_rep${r}.aiff"
      done
    done
    ((sentence_count++))
    if ((sentence_count < ${#sentences[@]})); then
      echo -e "${YELLOW}Generating row pause${NC}"
      say -v "$voice_name" "[[slnc 3000]]" -o "${tempfolder}/pause_${sentence_count}.aiff"
    fi
  done

  # Concatenate and convert to mp3
  sox $(ls "${tempfolder}"/*.aiff | sort -n) "voicereps_$(IFS=_; echo "${VOICE_SELECTIONS[*]}")_sentences.mp3"
  rm -rf "$tempfolder"
}

process_lines

echo -e "${BLUE}Audio file generated: voicereps_$(IFS=_; echo "${VOICE_SELECTIONS[*]}")_sentences.mp3${NC}"

